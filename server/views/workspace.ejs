<!DOCTYPE html>
<html>
<head>
  <title>Workspace - Coder Buddy</title>
  
</head>
<body>

  <h2>Workspace</h2>

  <form method="POST" action="/workspace/update/<%= project._id %>">
   
    <!-- Title -->
    <label>Title:</label><br>
    <input type="text" name="title" value="<%= project.title %>"><br><br>

    <!-- Description -->
    <label>Description:</label><br>
    <textarea name="description"><%= project.description %>
    
    </textarea><br><br>

    
        <% if (project.feedback && project.feedback.trim() !== "") { %>
          <br>
          <em>Feedback: <%= project.feedback %></em>
        <% } %>

        <br>
    
      
    <!-- Difficulty -->
    <label>Difficulty:</label><br>
    <select name="difficulty">
      <option value="Easy" <%= project.difficulty === "Easy" ? "selected" : "" %>>Easy</option>
      <option value="Medium" <%= project.difficulty === "Medium" ? "selected" : "" %>>Medium</option>
      <option value="Hard" <%= project.difficulty === "Hard" ? "selected" : "" %>>Hard</option>
    </select><br><br>

    <!-- Tech Stack -->
    <label>Tech Stack (comma separated):</label><br>
    <input type="text" name="techStack" value="<%= project.techStack ? project.techStack.join(',') : '' %>"><br><br>

    <!-- Category -->
    <label>Category:</label><br>
    <select name="category">
      <option value="Web Dev" <%= project.category === "Web Dev" ? "selected" : "" %>>Web Dev</option>
      <option value="DSA" <%= project.category === "DSA" ? "selected" : "" %>>DSA</option>
      <option value="College" <%= project.category === "College" ? "selected" : "" %>>College</option>
      <option value="Learning" <%= project.category === "Learning" ? "selected" : "" %>>Learning</option>
    </select><br><br>
    
<h3>code solution</h3>
<div id="editorContainer" style="width:50%; height:100px; border:1px solid #ccc; border-radius: 5%;"></div>


<!-- Button -->
<button id="runBtn" type="button">Run Code</button>

<!-- Terminal Output -->
<h4>Terminal Output:</h4>
<pre id="terminalOutput" style="background:#1e1e1e; color:#fff; padding:10px; border-radius:5px;width: 50%; min-height:100px;"></pre>


<!-- Save Solution Form -->
<form method="POST" action="/workspace/saveSolution/<%= project._id %>" 
      onsubmit="document.getElementById('solutionInput').value = editor.getValue();">
  <input type="hidden" name="solution" id="solutionInput">
  <button type="submit">Save Solution</button>
</form>

   
    <!-- Created At -->
    <p><strong>Created At:</strong> <%= project.createdAt ? new Date(project.createdAt).toDateString() : "N/A" %></p><br>

    <button type="submit">Save Changes</button>
    <button type="reset">reset</button>

  </form>
  <form method="POST" action="/workspace/delete/<%= project._id %> " onsubmit="return confirm('Are you sure you want to delete this project?');">
    <button type="submit">delete project</button>
  </form>
  
  <form method="POST" action="/workspace/submit/<%= project._id %>">
  <button type="submit">submit-task</button>
</form>


<script src="https://cdnjs.cloudflare.com/ajax/libs/require.js/2.3.6/require.min.js"></script>
<script>
require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.37.1/min/vs' }});

require(['vs/editor/editor.main'], function() {
    // Safely inject project.solution into a JS string
    const initialCode = "<%= project.solution ? project.solution.replace(/\\\\/g, '\\\\\\\\').replace(/`/g, '\\`').replace(/\\$/g, '\\$') : '' %>";

    window.editor = monaco.editor.create(document.getElementById('editorContainer'), {
        value: initialCode,
        language: 'javascript', // default language
        theme: 'vs-dark',
        automaticLayout: true
    });
});
</script>
<script>
document.getElementById('runBtn').addEventListener('click', async () => {
    const code = window.editor.getValue();
    const projectId = "<%= project._id %>";
    
    // Clear previous output
    const terminal = document.getElementById('terminalOutput');
    terminal.textContent = "Running...\n";

    try {
        const res = await fetch(`/workspace/runCode/${projectId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code })
        });

        const data = await res.json();
        terminal.textContent = data.output;
    } catch (err) {
        terminal.textContent = "Error running code: " + err;
    }
});
</script>


</body>
</html>