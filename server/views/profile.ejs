<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Profile</title>
</head>
<body>

<div class="container">
  <h2>Your Profile</h2>

  <form action="/profile/update" method="POST">

    <!-- BIO -->
    <label>Bio</label>
    <div class="display">
      <%= profile.bio && profile.bio.trim() !== "" ? profile.bio : "None" %>
    </div>
    <textarea name="bio"><%= profile.bio || "" %></textarea>

    <br/>

    <!-- SKILLS -->
    <label>Skills (comma separated)</label>
    <div class="display">
      <% if (profile.skills && profile.skills.length > 0) { %>
        <%= profile.skills.join(", ") %>
      <% } else { %>
        None
      <% } %>
    </div>
    <input 
      type="text" 
      name="skills" 
      value="<%= profile.skills ? profile.skills.join(',') : '' %>"
    />

    <br/>

    <!-- CONTACT LINKS -->
    <label>Contact</label>
    <div class="display">
      Email: <%= profile.contactLinks?.email || "None" %><br>
      Phone: <%= profile.contactLinks?.phone || "None" %><br>
      LinkedIn: <%= profile.contactLinks?.linkedin || "None" %><br>
      GitHub: <%= profile.contactLinks?.github || "None" %><br>
      Portfolio: <%= profile.contactLinks?.portfolio || "None" %>
    </div>

    <input name="email" placeholder="Email" value="<%= profile.contactLinks?.email || '' %>"/>
    <input name="phone" placeholder="Phone" value="<%= profile.contactLinks?.phone || '' %>"/>
    <input name="linkedin" placeholder="LinkedIn URL" value="<%= profile.contactLinks?.linkedin || '' %>"/>
    <input name="github" placeholder="GitHub URL" value="<%= profile.contactLinks?.github || '' %>"/>
    <input name="portfolio" placeholder="Portfolio URL" value="<%= profile.contactLinks?.portfolio || '' %>"/>

    <br/>

    <!-- STARS -->
    <label>Stars</label>
    <div class="display">
      <%= profile.starsCount || 0 %>
    </div>

    <br/>

    <!-- SAVE -->
    <button type="submit">Save Changes</button>

  </form>

  <br/>
  <a href="/"><button>Go Back to Home</button></a>

</div>

</body>
</html>